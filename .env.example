# ─── Obrigatórias (Segurança) ──────────────────────────────────────────────────
# Chave secreta para assinatura de JWT tokens. Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Senha padrão do admin no primeiro deploy (será usada apenas se o admin não existir)
ADMIN_DEFAULT_PASSWORD=

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:SENHA_SEGURA@db:5432/aldebaran
# DATABASE_URL=sqlite:///./aldebaran.db (apenas para desenvolvimento local)

# ─── JWT (opcional, valores padrão já definidos no código) ─────────────────────
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Ambiente ─────────────────────────────────────────────────────────────────
# ENVIRONMENT=production
# CORS_ORIGINS=https://seu-dominio.com
# ENABLE_HSTS=true

# ─── Integração de Pagamento (Asaas) ─────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# ─── E-mail (SMTP / Resend) ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── Frontend URL (para links de ativação) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Ngrok (apenas se necessário) ─────────────────────────────────────────────
NGROK_AUTHTOKEN=

# ─── PostgreSQL (Docker) ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=aldebaran
